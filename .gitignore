# State directory contents (except .gitkeep sentinel files)
state/inputs/*
state/designs/*
state/implementations/*
state/tests/*
state/decisions/*
state/build/*
state/runs/*
state/TRACE.json
state/cache/
state/sandbox_cache/
!state/**/.gitkeep

# Generated project artifacts
customer_database/

# Benchmark results
bench/results_*.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# Environment — never track actual env files
.env
.env.*
.env.local
.env.*.local
.venv/
venv/

# HMAC trace keys — per-run secrets, must not be committed.
# Legacy path (pre-P0-3): state/runs/<id>/.trace_key
# New path (P0-3): ~/.autonomy_engine/keys/<id>.key (outside the repo)
# .trace_key_moved is a breadcrumb left by the migration shim.
.trace_key
.trace_key_moved

# IDE
.idea/
.vscode/
*.swp
*.swo

# Claude Code
/.claude/
CLAUDE_CODE_*.md

# Exported docs (root only)
/*.docx
/*.html

# Shareable zip artifacts (built by `make share-zip`)
*.zip

# Coverage
htmlcov/
.coverage
coverage.xml

# Streamlit secrets — contains API keys for cloud deployment, never commit
.streamlit/secrets.toml

# OS
.DS_Store
Thumbs.db
