# State directory contents (except .gitkeep sentinel files)
state/inputs/*
state/designs/*
state/implementations/*
state/tests/*
state/decisions/*
state/build/*
state/runs/*
state/TRACE.json
state/cache/
state/sandbox_cache/
!state/**/.gitkeep

# Generated project artifacts
customer_database/

# Benchmark results
bench/results_*.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# Environment — never track actual env files
.env
.env.local
.env.*.local
.venv/
venv/

# HMAC trace keys — per-run secrets, must not be committed
.trace_key

# IDE
.idea/
.vscode/
*.swp
*.swo

# Claude Code
/.claude/
CLAUDE_CODE_*.md

# Exported docs (root only)
/*.docx
/*.html

# Coverage
htmlcov/
.coverage
coverage.xml

# OS
.DS_Store
Thumbs.db
